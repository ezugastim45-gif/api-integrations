      "id": "a1b2c3d4-0001-0001-0001-000000000003",
      "name": "Formatear Precios ATLAS",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// ATLAS CHRONOS — Procesamiento de precios para Notion / webhook destino\n// Consumido por: agente ATLAS en ZumaIntelligence\n// Acción: enviar a Notion database o webhook interno\n\nconst data = items[0].json;\n\nconst summary = {\n  timestamp: data.timestamp,\n  agente: 'ATLAS CHRONOS',\n  precios: {\n    BTC: { USD: data.btc_usd, MXN: data.btc_mxn, cambio_24h: `${parseFloat(data.btc_24h_change).toFixed(2)}%` },\n    ETH: { USD: data.eth_usd, MXN: data.eth_mxn, cambio_24h: `${parseFloat(data.eth_24h_change).toFixed(2)}%` },\n    USDC: { USD: data.usdc_usd }\n  },\n  alerta: Math.abs(parseFloat(data.btc_24h_change)) > 5 ? '⚠️ Movimiento >5% BTC' : null\n};\n\nconsole.log('[ATLAS]', JSON.stringify(summary, null, 2));\n\nreturn [{ json: summary }];"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000004",
      "name": "ATLAS — Procesar y Alertar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "resource": "databasePage",
        "operation": "create",
        "databaseId": {
          "__rl": true,
          "value": "677963db09524372b29ae63861a9d7ca",
          "mode": "id"
        },
        "title": "={{ $json.timestamp.substring(0,16).replace('T',' ') + ' | BTC $' + $json.precios.BTC.USD }}",
        "propertiesUi": {
          "propertyValues": [
            {
              "key": "BTC_USD",
              "numberValue": "={{ $json.precios.BTC.USD }}"
            },
            {
              "key": "BTC_MXN",
              "numberValue": "={{ $json.precios.BTC.MXN }}"
            },
            {
              "key": "BTC_24h_pct",
              "numberValue": "={{ parseFloat($json.precios.BTC.cambio_24h) }}"
            },
            {
              "key": "ETH_USD",
              "numberValue": "={{ $json.precios.ETH.USD }}"
            },
            {
              "key": "ETH_MXN",
              "numberValue": "={{ $json.precios.ETH.MXN }}"
            },
            {
