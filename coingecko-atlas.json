              "stringValue": "={{ $json.bitcoin.mxn }}"
            },
            {
              "name": "btc_24h_change",
              "stringValue": "={{ $json.bitcoin.usd_24h_change }}"
            },
            {
              "name": "eth_usd",
              "stringValue": "={{ $json.ethereum.usd }}"
            },
            {
              "name": "eth_mxn",
              "stringValue": "={{ $json.ethereum.mxn }}"
            },
            {
              "name": "eth_24h_change",
              "stringValue": "={{ $json.ethereum.usd_24h_change }}"
            },
            {
              "name": "usdc_usd",
              "stringValue": "={{ $json['usd-coin'].usd }}"
            },
            {
              "name": "fuente",
              "stringValue": "CoinGecko API v3"
            },
            {
              "name": "agente",
              "stringValue": "ATLAS CHRONOS"
            },
            {
              "name": "timestamp",
              "stringValue": "={{ new Date().toISOString() }}"
            }
          ]
        },
        "options": {}
