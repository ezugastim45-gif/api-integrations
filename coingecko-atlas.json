            },
            {
              "key": "USDC_USD",
              "numberValue": "={{ $json.precios.USDC.USD }}"
            },
            {
              "key": "Alerta",
              "selectValue": "={{ $json.alerta !== null ? $json.alerta : '✅ Normal' }}"
            },
            {
              "key": "Fuente",
              "selectValue": "CoinGecko API v3"
            },
            {
              "key": "Timestamp",
              "dateValue": "={{ $json.timestamp }}",
              "includeTime": true
            }
